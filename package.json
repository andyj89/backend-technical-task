{
  "name": "backend-technical-task",
  "version": "1.0.0",
  "description": "## Overview",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "vitest src",
    "test:integration": "vitest tests/integration --no-file-parallelism",
    "test:load": "./load-tests.sh",
    "build": "rm -rf dist && tsc",
    "dev": "tsx watch src/index.ts",
    "dev:debug": "node --inspect --import tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andyj89/backend-technical-task.git"
  },
  "author": "",
